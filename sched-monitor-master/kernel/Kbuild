# Module name
obj-m := sched_monitor.o

# Object files
sched_monitor-objs := main.o trace_hook.o ring_buffer.o \
                      netlink_comm.o async_worker.o config.o stats.o

obj-$(CONFIG_KUNIT) += sched_monitor_kunit.o
sched_monitor_kunit-objs := kunit_test.o config.o ring_buffer.o stats.o

# Compiler flags
ccflags-y := -Wall -Werror
ccflags-$(CONFIG_SCHED_MONITOR_DEBUG) := -DDEBUG

# Include paths
ccflags-y += -I$(src)/../include
