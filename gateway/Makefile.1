# Gateway Makefile
# 支持x86和ARM交叉编译

CC ?= gcc
CROSS_COMPILE ?= arm-linux-gnueabihf-

# 编译目标: x86 或 arm
TARGET ?= x86

ifeq ($(TARGET), arm)
    CC = $(CROSS_COMPILE)gcc
    AR = $(CROSS_COMPILE)ar
endif

# 目录
SRC_DIR = src
INC_DIR = include
BUILD_DIR = build
OBJ_DIR = $(BUILD_DIR)/obj
BIN_DIR = $(BUILD_DIR)/bin

# 源文件 - 基础模块
BASE_SRCS = $(SRC_DIR)/app_config.c \
            $(SRC_DIR)/mqtt/app_mqtt_v2.c \
            $(SRC_DIR)/mqtt/app_mqtt_compat.c \
            $(SRC_DIR)/app_bluetooth.c \
            $(SRC_DIR)/app_buffer.c \
			$(SRC_DIR)/app_device.c \
			$(SRC_DIR)/app_message.c \
			$(SRC_DIR)/app_persistence.c \
			$(SRC_DIR)/app_router.c \
			$(SRC_DIR)/app_runner.c \
			$(SRC_DIR)/app_serial.c \
			$(SRC_DIR)/app_task.c \
			$(SRC_DIR)/daemon/daemon_process.c \
			$(SRC_DIR)/daemon/daemon_runner.c \
			thirdparty/cJSON/cJSON.c \
			thirdparty/log.c/log.c \
			main.c
			

# 源文件 - DDS模块
DDS_SRCS = $(SRC_DIR)/dds/app_dds.c \
           $(SRC_DIR)/dds/app_transport.c

# 源文件 - Modbus模块
MODBUS_SRCS = $(SRC_DIR)/modbus/app_modbus.c

# 源文件 - OTA模块
OTA_SRCS = $(SRC_DIR)/ota/app_ota.c

# 所有源文件
SRCS = $(BASE_SRCS) $(DDS_SRCS) $(MODBUS_SRCS) $(OTA_SRCS)

# 目标文件
OBJS = $(SRCS:$(SRC_DIR)/%.c=$(OBJ_DIR)/%.o)

# 目标文件
TARGET_BIN = $(BIN_DIR)/gateway
TARGET_LIB = $(BUILD_DIR)/libgateway.a

# 编译选项
CFLAGS = -Wall -Wextra -O2 -g
CFLAGS += -I$(INC_DIR)
CFLAGS += -D_GNU_SOURCE

# DDS编译选项(可选)
ifdef USE_DDS
    CFLAGS += -DUSE_CYCLONE_DDS
    LDFLAGS += -lddsc
endif

# 链接库
LDFLAGS = -lpthread -lsqlite3 -lpaho-mqtt3c -lcurl -lssl -lcrypto

# 调试信息
$(info Building for $(TARGET))
$(info CC: $(CC))

# 默认目标
all: dirs $(TARGET_BIN)

# 创建目录
dirs:
	@mkdir -p $(OBJ_DIR)/dds $(OBJ_DIR)/modbus $(OBJ_DIR)/ota $(BIN_DIR)

# 链接
$(TARGET_BIN): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)
	@echo "Build complete: $@"

# 编译源文件 - 基础模块
$(OBJ_DIR)/%.o: $(SRC_DIR)/%.c
	$(CC) $(CFLAGS) -c -o $@ $<

# 编译源文件 - DDS模块
$(OBJ_DIR)/dds/%.o: $(SRC_DIR)/dds/%.c
	$(CC) $(CFLAGS) -c -o $@ $<

# 编译源文件 - Modbus模块
$(OBJ_DIR)/modbus/%.o: $(SRC_DIR)/modbus/%.c
	$(CC) $(CFLAGS) -c -o $@ $<

# 编译源文件 - OTA模块
$(OBJ_DIR)/ota/%.o: $(SRC_DIR)/ota/%.c
	$(CC) $(CFLAGS) -c -o $@ $<

# 静态库
lib: $(TARGET_LIB)

$(TARGET_LIB): $(OBJS)
	$(AR) rcs $@ $^
	@echo "Static library created: $@"

# 清理
clean:
	rm -rf $(BUILD_DIR)
	@echo "Clean complete"

# 安装 (需要root权限)
install: $(TARGET_BIN)
	install -d /usr/local/bin
	install -d /etc/gateway
	install -d /var/log
	install -d /var/lib/gateway
	install -m 755 $(TARGET_BIN) /usr/local/bin/
	install -m 644 config/gateway.ini /etc/gateway/
	@echo "Install complete"

# 运行测试
test: $(TARGET_BIN)
	./$(TARGET_BIN)

# 帮助
help:
	@echo "Available targets:"
	@echo "  all       - Build gateway (default)"
	@echo "  lib       - Build static library"
	@echo "  clean     - Remove build files"
	@echo "  install   - Install to system"
	@echo "  test      - Run gateway"
	@echo ""
	@echo "Options:"
	@echo "  TARGET=x86   - Build for x86 (default)"
	@echo "  TARGET=arm   - Build for ARM (cross-compile)"
	@echo "  USE_DDS=1    - Enable DDS support"
	@echo ""
	@echo "Example:"
	@echo "  make                    # Build for x86"
	@echo "  make TARGET=arm         # Build for ARM"
	@echo "  make USE_DDS=1          # Build with DDS support"

.PHONY: all dirs lib clean install test help
